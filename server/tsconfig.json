{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "../",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@kodo/shared/*": ["../shared/*"]
    }
  },
  "include": ["src/**/*", "../shared/**/*", "prisma.config.ts"],
  "exclude": ["node_modules", "dist"]
}
